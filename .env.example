# Flask
FLASK_DEBUG=false
FLASK_PORT=5001

# スクレイピング
SCRAPE_TIMEOUT=30
SCRAPE_RETRY_ATTEMPTS=3

# データストア
MAX_RECORDS=700

# Cookie 警告（この時間経過で再設定を推奨）
COOKIE_WARN_HOURS=24

# API レート制限（例: 3 per minute）
SCRAPE_RATE_LIMIT=3 per minute

# Render 用（データ送信側で設定）
# RENDER_URL=https://auto-check.onrender.com
# API_SECRET=Renderダッシュボードで生成された値
